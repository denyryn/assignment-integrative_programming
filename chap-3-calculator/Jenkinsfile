pipeline {
    agent any
    
    triggers {
        // Poll SCM every minute (for demo)
        pollSCM('* * * * *')
    }
    
    environment {
        PYTHONUNBUFFERED = '1'  // For real-time output
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo '[SUCCESS] Code checked out successfully'
                sh 'ls -la'  // Show files for debugging
            }
        }
        
        stage('Setup Python Environment') {
            steps {
                echo '[INFO] Setting up Python environment...'
                sh 'python3 --version'
                sh 'pip3 install --upgrade pip'
                // Install any requirements if needed
                sh 'pip3 install -r requirements.txt || echo "No requirements.txt found"'
            }
        }
        
        stage('Run Tests with Verbose Output') {
            steps {
                echo '[INFO] Running tests with verbose output (-v)...'
                echo '=================================================='
                
                // THIS IS THE KEY COMMAND - Running test with -v flag
                sh 'python3 test-calculator.py -v'
                
                echo '=================================================='
                echo '[SUCCESS] All tests passed successfully!'
            }
        }
        
        stage('Additional Linting (Optional)') {
            steps {
                echo '[INFO] Running code quality checks...'
                echo '[INFO] Linting completed'
            }
        }
    }
    
    post {
        success {
            echo '[SUCCESS] Pipeline succeeded! All tests passed ✅'
            // Optional: Send success notification
            // emailext subject: "Build Passed", body: "All tests passed!"
        }
        
        failure {
            echo '[ERROR] Pipeline failed! Tests failed ❌'
            echo '[ERROR] Check the test output above for details'
            // Optional: Send failure notification
            // emailext subject: "Build Failed", body: "Please check the logs"
        }
        
        always {
            echo '[INFO] Pipeline execution completed'
            // Clean up or archive artifacts
            // archiveArtifacts artifacts: 'test-reports/*.xml'
        }
    }
}