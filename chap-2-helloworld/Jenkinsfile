pipeline {
    agent any

    environment {
        DOCKER_REPO      = credentials('DOCKER_REPO')
        STAGING_HOST     = credentials('STAGING_HOST')
        STAGING_USER     = credentials('STAGING_USER')
        CREDENTIALS_ID   = 'staging-ssh-key'
        BASE_IMAGE       = 'python:3.11-slim'
        APP_PORT         = '8000'
        VERSION_TAG      = "${new Date().format('yyyyMMdd-HHmmss')}"
    }

    stages {
        stage("Build & Push Docker Image") {
            steps {
                script {
                    def fullImage = "${DOCKER_REPO}:${VERSION_TAG}"
                    sh "docker build --build-arg BASE_IMAGE=${BASE_IMAGE} --build-arg APP_PORT=${APP_PORT} -t ${fullImage} ."
                    sh "docker push ${fullImage}"
                }
            }
        }

        stage("Deploy to Staging") {
            steps {
                sshagent(credentials: ["${CREDENTIALS_ID}"]) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${STAGING_USER}@${STAGING_HOST} \
                            "kubectl set image deployment/flask-hello \
                                flask-hello=${DOCKER_REPO}:${VERSION_TAG}"
                    """
                }
            }
        }

        stage("Performance Testing") {
            steps {
                sh "chmod +x performance-test.sh"
                sh "APP_URL=http://${STAGING_HOST}:30007/hello ./performance-test.sh"
            }
        }
    }

    post {
        success {
            echo "Pipeline succeeded — deployed ${DOCKER_REPO}:${VERSION_TAG}"
        }
        failure {
            echo "Pipeline failed — check logs above."
        }
    }
}
