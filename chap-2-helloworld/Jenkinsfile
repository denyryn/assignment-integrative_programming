pipeline {
    agent any

    environment {
        DOCKER_REPO      = credentials('DOCKER_REPO')
        STAGING_HOST     = credentials('STAGING_HOST')
        BASE_IMAGE       = 'python:3.11-slim'
        APP_PORT         = '8000'
        INGRESS_PORT     = '30080'
        PROJECT_DIR      = 'chap-2-helloworld'
        VERSION_TAG      = "${new Date().format('yyyyMMdd-HHmmss')}"
    }

    stages {
        stage("Build Docker Image") {
            steps {
                dir(PROJECT_DIR) {
                    sh 'docker build --build-arg BASE_IMAGE=$BASE_IMAGE --build-arg APP_PORT=$APP_PORT -t "$DOCKER_REPO:$VERSION_TAG" .'
                }
            }
        }

        stage("Push Docker Image") {
            steps {
                dir(PROJECT_DIR) {
                    withCredentials([usernamePassword(credentialsId: 'docker-registry', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        script {
                            sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
                            sh 'docker push "$DOCKER_REPO:$VERSION_TAG"'
                        }
                    }
                }
            }
        }

        stage("Deploy to Staging") {
            steps {
                dir(PROJECT_DIR) {
                    withKubeConfig(credentialsId: 'kubeconfig-staging') {
                        sh "kubectl config use-context staging"
                        sh "sed -i 's|{{VERSION}}|\${DOCKER_REPO}:\${VERSION_TAG}|g' deployment.yaml"
                        sh "kubectl apply -f deployment.yaml --insecure-skip-tls-verify=true"
                    }
                }
            }
        }

        stage("Performance Testing") {
            steps {
                dir(PROJECT_DIR) {
                    sh '''
                        chmod +x performance-test.sh
                        APP_URL="http://$STAGING_HOST:$INGRESS_PORT/hello" ./performance-test.sh
                    '''
                }
            }
        }

        stage("Deploy to Production") {
            steps {
                dir(PROJECT_DIR) {
                    withKubeConfig(credentialsId: 'kubeconfig-prod') {
                        sh "kubectl config use-context production"
                        sh "sed -i 's|{{VERSION}}|\${DOCKER_REPO}:\${VERSION_TAG}|g' deployment.yaml"
                        sh "kubectl apply -f deployment.yaml --insecure-skip-tls-verify=true"
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline succeeded — deployed ${DOCKER_REPO}:${VERSION_TAG} to Staging and Production!"
        }
        failure {
            echo 'Pipeline failed — check logs above.'
        }
    }
}