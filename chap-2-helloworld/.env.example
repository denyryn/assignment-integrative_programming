# =============================================================================
# LOCAL DEVELOPMENT REFERENCE ONLY
# =============================================================================
# In Jenkins, these are managed via Jenkins Credentials (Option B):
#   - DOCKER_REPO      → Secret text credential (ID: DOCKER_REPO)
#   - STAGING_HOST     → Secret text credential (ID: STAGING_HOST)
#   - STAGING_USER     → Secret text credential (ID: STAGING_USER)
#   - SSH key          → SSH credential (ID: staging-ssh-key)
#
# This file is for local dev/testing only. It is gitignored and NOT used
# by the Jenkins pipeline.
# =============================================================================

# Docker build settings
BASE_IMAGE=python:3.11-slim
APP_PORT=8000

# Docker registry (e.g. docker.io/youruser/flask-hello)
DOCKER_REPO=docker.io/youruser/flask-hello

# Staging server SSH connection (use Tailscale IP or MagicDNS name)
STAGING_HOST=your-staging-ip-or-hostname
STAGING_USER=deploy

# Jenkins SSH credential ID (configured in Jenkins > Credentials)
JENKINS_CREDENTIALS_ID=staging-ssh-key
